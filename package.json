{
  "name": "productivity-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test e2e/visual-regression.spec.ts",
    "test:accessibility": "playwright test e2e/accessibility.spec.ts",
    "test:all": "npm run test:run && npm run test:integration && npm run test:e2e",
    "test:summary": "node scripts/test-summary.js",
    "db:seed": "tsx prisma/seed.ts",
    "analyze": "ANALYZE=true next build",
    "analyze:dev": "ANALYZE=true next dev"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@dnd-kit/core": "^6.3.1",
